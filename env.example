# Your store's myshopify.com domain, no protocol
SHOPIFY_STORE_DOMAIN=your-store.myshopify.com

# Admin API access token from your custom app (Shopify Admin > Settings > Apps and sales channels > Develop apps)
SHOPIFY_ADMIN_ACCESS_TOKEN=shpat_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Admin API version to call
SHOPIFY_API_VERSION=2026-07
